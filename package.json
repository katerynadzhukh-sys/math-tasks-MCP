{
  "name": "mcp-blanko",
  "version": "1.0.0",
  "description": "MCP Server Template — a starting point for building your own MCP server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "start:stdio": "node dist/index.js --transport=stdio",
    "start:sse": "node dist/index.js --transport=sse"
  },
  "keywords": ["mcp", "model-context-protocol", "template"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
